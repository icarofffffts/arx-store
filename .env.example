# =============================================================================
# ARX Store — Environment Variables
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.arxdevs.xyz
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ── ARX Auth Portal ───────────────────────────────────────────────────────────
ARX_AUTH_PORTAL_URL=https://auth.arxdevs.xyz
ARX_JWT_SECRET=  # mesmo secret do ArxAuthPortal

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=ARX Store

# ── Bot ───────────────────────────────────────────────────────────────────────
BOT_DISCORD_TOKEN=     # mesmo do DISCORD_BOT_TOKEN (ou token proprio)
BOT_SUPABASE_URL=      # mesmo do NEXT_PUBLIC_SUPABASE_URL
BOT_SUPABASE_KEY=      # service_role

# ── Custom Bot Service ────────────────────────────────────────────────────────
# Email para notificacoes de novos pedidos de bot personalizado
CUSTOM_BOT_NOTIFICATION_EMAIL=
