# =============================================================================
# ARX Store — Environment Variables
# =============================================================================

# ── NextAuth ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # openssl rand -base64 32

# ── Discord ─────────────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ── Supabase ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://supabase.arxdevs.xyz
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── ARX Auth Portal ─────────────────────────────────────────────────────────────
ARX_AUTH_PORTAL_URL=https://auth.arxdevs.xyz
ARX_JWT_SECRET=

# ── Mercado Pago ────────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
MERCADOPAGO_ACCESS_TOKEN=   # same, bot uses this name
MERCADO_PAGO_WEBHOOK_SECRET=

# ── Site ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://store.arxdevs.xyz
NEXT_PUBLIC_SITE_NAME=ARX Store

# ── Bot ─────────────────────────────────────────────────────────────────────────
BOT_DISCORD_TOKEN=          # can be same as DISCORD_BOT_TOKEN
BOT_SUPABASE_URL=           # same as NEXT_PUBLIC_SUPABASE_URL
BOT_SUPABASE_KEY=           # service_role key
